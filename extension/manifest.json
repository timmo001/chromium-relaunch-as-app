{
  "manifest_version": 3,
  "name": "Relaunch As App",
  "version": "0.1.0",
  "description": "Launch the current page in an app window via omarchy-launch-webapp.",
  "permissions": ["activeTab", "contextMenus", "nativeMessaging", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Relaunch current page as app",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "key": ""
}
